{
  "displayName": "Agentic Platform - Customer Resolution Hub",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "height": 4,
        "widget": {
          "title": "Agent Latency (p99)",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "LINE",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_99"
                    },
                    "filter": "metric.type=\"aiplatform.googleapis.com/prediction/latency\" resource.type=\"aiplatform.googleapis.com/ReasoningEngine\""
                  }
                }
              }
            ]
          }
        },
        "width": 6,
        "yPos": 0
      },
      {
        "height": 4,
        "widget": {
          "title": "Tool Execution Rate",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "STACKED_AREA",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE"
                    },
                    "filter": "metric.type=\"aiplatform.googleapis.com/agent/tool_use_count\" resource.type=\"aiplatform.googleapis.com/ReasoningEngine\""
                  }
                }
              }
            ]
          }
        },
        "width": 6,
        "xPos": 6,
        "yPos": 0
      },
      {
        "height": 4,
        "widget": {
          "title": "Agent Fulfillment Score (Vertex AI Eval)",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "LINE",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_MEAN"
                    },
                    "filter": "metric.type=\"custom.googleapis.com/agent/evaluation/fulfillment_score\" resource.type=\"global\""
                  }
                }
              }
            ]
          }
        },
        "width": 12,
        "yPos": 4
      }
    ]
  }
}
