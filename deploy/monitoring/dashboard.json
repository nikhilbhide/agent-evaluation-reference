{
  "displayName": "Agentic Platform - Customer Resolution Hub",
  "dashboardFilters": [],
  "widgets": [
    {
      "title": "Agent Latency (p99)",
      "xyChart": {
        "dataSets": [
          {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"aiplatform.googleapis.com/prediction/latency\" resource.type=\"aiplatform.googleapis.com/ReasoningEngine\"",
                "aggregation": {
                  "perSeriesAligner": "ALIGN_PERCENTILE_99",
                  "alignmentPeriod": "60s"
                }
              }
            },
            "plotType": "LINE"
          }
        ]
      }
    },
    {
      "title": "Tool Execution Success Rate",
      "xyChart": {
        "dataSets": [
          {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"aiplatform.googleapis.com/agent/tool_use_count\" resource.type=\"aiplatform.googleapis.com/ReasoningEngine\" metric.label.status=\"success\"",
                "aggregation": {
                  "perSeriesAligner": "ALIGN_RATE",
                  "alignmentPeriod": "60s"
                }
              }
            },
            "plotType": "STACKED_AREA"
          }
        ]
      }
    },
    {
      "title": "Model Armor Security Blocks",
      "xyChart": {
        "dataSets": [
          {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"aiplatform.googleapis.com/security/model_armor_blocks\" resource.type=\"aiplatform.googleapis.com/ReasoningEngine\"",
                "aggregation": {
                  "perSeriesAligner": "ALIGN_COUNT",
                  "alignmentPeriod": "60s"
                }
              }
            },
            "plotType": "BAR"
          }
        ]
      }
    },
    {
      "title": "Agent Fulfillment Score (Vertex AI Eval)",
      "xyChart": {
        "dataSets": [
          {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"custom.googleapis.com/agent/evaluation/fulfillment_score\" resource.type=\"global\"",
                "aggregation": {
                  "perSeriesAligner": "ALIGN_MEAN",
                  "alignmentPeriod": "3600s"
                }
              }
            },
            "plotType": "LINE"
          }
        ]
      }
    }
  ]
}
