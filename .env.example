# ── Environment Variables Template ─────────────────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# .env is in .gitignore — never commit it.
#
# Usage:
#   cp .env.example .env
#   source .env    (or use python-dotenv / direnv)

# ── Required for evaluation (CI mode) ─────────────────────────────────────────
# Your GCP project ID. Used by agent-eval and Vertex AI SDK.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Optional overrides ─────────────────────────────────────────────────────────
# GCP region for Vertex AI calls (default: us-central1)
GCP_LOCATION=us-central1

# Gemini model for the mock agent (default: gemini-2.5-flash)
MODEL_NAME=gemini-2.5-flash

# ── CD mode — only needed when evaluating a live deployed agent ────────────────
# URL of a locally running agent or a port-forwarded canary pod.
# Leave empty for CI mode (uses mock agent).
# AGENT_ENDPOINT=http://localhost:8080
