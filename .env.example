# ── Environment Variables Template ─────────────────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# .env is in .gitignore — never commit it.
#
# Usage:
#   cp .env.example .env
#   source .env    (or use python-dotenv / direnv)

# ════════════════════════════════════════════════════════════════════════════
# REQUIRED — every script reads at least these
# ════════════════════════════════════════════════════════════════════════════

# GCP project ID. No default — scripts fail fast if this is missing.
GCP_PROJECT=your-gcp-project-id
# Alias used by agent-eval CLI / Vertex AI SDK.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP region for Vertex AI / Agent Engine / Cloud Run.
GCP_LOCATION=us-central1

# GCS staging bucket for Agent Engine pickles. Default: gs://${GCP_STAGING_BUCKET_PREFIX}-${GCP_PROJECT}
# GCP_STAGING_BUCKET=gs://agent-eval-staging-your-gcp-project-id

# Override only the bucket-name prefix; final URL becomes gs://<prefix>-<project>.
# GCP_STAGING_BUCKET_PREFIX=agent-eval-staging


# ════════════════════════════════════════════════════════════════════════════
# MODELS — every model name is overridable
# ════════════════════════════════════════════════════════════════════════════

# Orchestrator runs Pro by default (routing + reasoning quality).
# ORCHESTRATOR_MODEL=gemini-2.5-pro

# All specialists (billing, account, technical) and the mock CI agent.
# SPECIALIST_MODEL=gemini-2.5-flash

# Memory Bank: model that summarizes sessions into memories, and embedder
# used for similarity search at recall time.
# MEMORY_BANK_GENERATION_MODEL=gemini-2.5-flash
# MEMORY_BANK_EMBEDDING_MODEL=text-embedding-005

# Red-team adversarial generator + auto-judge.
# REDTEAM_ATTACKER_MODEL=gemini-2.5-flash
# REDTEAM_JUDGE_MODEL=gemini-2.5-flash

# Override for the CI mock agent specifically (else falls back to SPECIALIST_MODEL).
# MOCK_AGENT_MODEL=gemini-2.5-flash


# ════════════════════════════════════════════════════════════════════════════
# AGENT DISPLAY NAMES — only override to run side-by-side with the reference stack
# ════════════════════════════════════════════════════════════════════════════
# These are the canonical Agent Engine display names. They double as the
# teardown-match keys in redeploy_all.py and the ABOM agent_name, so they must
# stay consistent across all scripts in a given deployment.
# ORCHESTRATOR_DISPLAY_NAME=customer-resolution-orchestrator
# BILLING_DISPLAY_NAME=billing-specialist
# ACCOUNT_DISPLAY_NAME=account-specialist
# TECHNICAL_DISPLAY_NAME=technical-specialist


# ════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT TARGETS — populated by the deploy scripts; you usually don't set these
# ════════════════════════════════════════════════════════════════════════════

# MCP server URL (Cloud Run). Set automatically by deploy_mcp_cloud_run.sh,
# also persisted to mcp_server_url.txt at repo root.
# MCP_SERVER_URL=https://mcp-server-XXX-uc.a.run.app

# Model Armor template for prompt-injection / data-exfil enforcement.
# Set automatically by setup_model_armor.py, persisted to model_armor_template.txt.
# MODEL_ARMOR_TEMPLATE=projects/${GCP_PROJECT}/locations/${GCP_LOCATION}/templates/techcorp-security-gate

# Orchestrator Reasoning Engine resource. Required by load_test_agent_engine.py.
# Persisted to deployed_agent_resource.txt by deploy_agent_engine.py.
# ORCHESTRATOR_RESOURCE=projects/.../reasoningEngines/...

# Live agent endpoint for the eval CLI in CD mode (Reasoning Engine resource
# name OR an HTTP URL). Leave unset for CI mode (uses local mock agent).
# AGENT_ENDPOINT=projects/.../reasoningEngines/...


# ════════════════════════════════════════════════════════════════════════════
# QUALITY GATES & OPS KNOBS
# ════════════════════════════════════════════════════════════════════════════

# Red-team severity that fails the gate (low | medium | high). Default: high.
# REDTEAM_THRESHOLD=high

# Memory Bank persistence wait (seconds) used by smoke_test_agents.py.
# MEMORY_PERSIST_WAIT_SECONDS=30

# Load-test defaults are intentionally conservative. Override for soak runs.
# TARGET_QPS=1.0
# DURATION_SECONDS=120
# CONCURRENCY=4

# BigQuery telemetry sink (used by walkthrough_report.py + trigger_tuning.py).
# BQ_LOGS_DATASET=agent_telemetry
# BQ_LOGS_TABLE=agent_traces

# Tuning loop: dry-run by default. Set to 0 to actually submit a Vertex AI SFT job.
# TUNING_DRY_RUN=1
# TUNING_SOURCE_MODEL=gemini-2.5-flash

# Cloud Monitoring notification fan-out for setup_alerting.py.
# ALERT_EMAILS=oncall@example.com,sec@example.com
# ALERT_PUBSUB_TOPIC=projects/${GCP_PROJECT}/topics/alerts
